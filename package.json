{
  "name": "landingpage-react-template",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "bootstrap": "^5.3.3",
    "emailjs-com": "^3.2.0",
    "lightgallery": "^2.8.3",
    "react": "^18.3.1",
    "react-bootstrap": "^2.10.6",
    "react-dom": "^18.3.1",
    "react-image-gallery": "^1.4.0",
    "react-router-dom": "^6.28.0",
    "react-scripts": "^5.0.1",
    "react-speech-kit": "^3.0.1",
    "smooth-scroll": "^16.1.3",
    "styled-components": "^6.1.13"
  },
  "scripts": {
    "start": "export NODE_OPTIONS=--openssl-legacy-provider && react-scripts start",
    "build": "BUILD_PATH='./build-prod' GENERATE_SOURCEMAP=false REACT_APP_STATE=production NODE_ENV=production react-scripts build --max_old_space_size=8000 build",
    "s3upload": "aws s3 sync build-prod/ s3://waddan-website --acl public-read --profile pave >> /dev/null && aws cloudfront create-invalidation --distribution-id E2C6I0PFBU6YY3 --paths / --profile pave >> /dev/null",
    "deploy": "npm run build && npm run s3upload",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
